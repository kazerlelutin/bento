{
  "name": "kazerlelutin",
  "version": "4.9.2",
  "author": {
    "email": "contact@ben-to.fr",
    "name": "Benoist Bouteiller",
    "url": "https://bouteiller.contact"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/kazerlelutin/kazerlelutin.git"
  },
  "main": "index.js",
  "bugs": {
    "url": "https://github.com/kazerlelutin/kazerlelutin/issues"
  },
  "description": "Bento - An interactive recipe generator with pixel art, allowing you to create recipe variants from modular bases",
  "homepage": "https://github.com/kazerlelutin/kazerlelutin#readme",
  "keywords": [
    "bento",
    "recipe-generator",
    "cooking",
    "pixel-art",
    "food",
    "recipes",
    "interactive",
    "modular",
    "variants",
    "culinary",
    "gastronomy",
    "meal-planning",
    "cooking-app",
    "recipe-builder",
    "food-app",
    "culinary-tools",
    "recipe-variations",
    "cooking-assistant",
    "meal-prep",
    "food-creativity"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "bun --hot index.html --spa",
    "preview": "bun run build && bun run server.ts",
    "start": "bun run server.ts",
    "test": "bun test --max-concurrency 1",
    "coverage": "bun test --coverage",
    "test:integration": "bunx --bun cucumber-js",
    "build": "bun build ./index.html --minify --outdir=dist && bun scripts/copy-static.ts && bun scripts/prerender.ts",
    "docs:features": "bun scripts/generate-feature-docs.ts",
    "badge:coverage": "bun scripts/generate-coverage-badge.ts",
    "sitemap": "bun scripts/generate-sitemap.ts",
    "seo": "bun scripts/generate-sitemap.ts",
    "validate:seo": "bun scripts/validate-sitemap.ts",
    "validate:recipes": "bun scripts/validate-recipe-system.ts",
    "knip": "knip"
  },
  "update": "2025-04-26",
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@happy-dom/global-registrator": "^17.6.3",
    "@types/bun": "^1.2.18",
    "@types/node": "^25.3.5",
    "bun-types": "^1.2.15",
    "happy-dom": "^17.0.0",
    "knip": "^5.86.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3"
  }
}
